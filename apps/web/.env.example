# Database Configuration
MONGODB_URI=mongodb://localhost:27017/observability-os

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Auth Secret Configuration
JWT_SECRET=your_jwt_secret_token_here

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# App URL Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DOCS_URL=http://localhost:3001

# Cron Security Secret (for SLO & Email triggering)
CRON_SECRET=dev_cron_secret_123

# AI / LLM Keys (Optional: Falls back to mock heuristics if missing)
# AICREDITS_API_KEY=your_aicredits_api_key
# AICREDITS_MODEL=anthropic/claude-3.5-haiku
# ANTHROPIC_API_KEY=your_anthropic_api_key
# OPENAI_API_KEY=your_openai_api_key

# Integrations (Optional)
# RESEND_API_KEY=your_resend_api_key

# Razorpay Subscription Configuration
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Sentry (error tracking)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# PostHog (product analytics & feature flags)
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

