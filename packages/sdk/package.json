{
  "name": "@observability-os/sdk",
  "version": "0.1.2",
  "license": "MIT",
  "keywords": [
    "observability",
    "logging",
    "logger",
    "telemetry",
    "sdk",
    "typescript",
    "zero-dependency",
    "monitoring",
    "log-analytics"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "typescript": "5.9.2"
  }
}
